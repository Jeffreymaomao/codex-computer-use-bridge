# Copy to .env and fill in. .env is gitignored; this example file is committed.
# Used by server.sh (the tunnel-client launcher).

# Required: your tunnel id from
# https://platform.openai.com/settings/organization/tunnels
TUNNEL_ID=tunnel_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (defaults shown):
# TUNNEL_PROFILE=local-stdio
# TUNNEL_SAMPLE=sample_mcp_stdio_local
# MCP_COMMAND=node ./src/mcp-server.js
# TUNNEL_FORCE_INIT=0   # set to 1 to re-create the tunnel profile from scratch
